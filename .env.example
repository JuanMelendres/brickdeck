# .env.example

POSTGRES_DB=your_db_name_here
POSTGRES_USER=your_username_here
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

SPRING_PROFILES_ACTIVE=local

REBRICKABLE_BASE_URL=https://rebrickable.com/api/v3
REBRICKABLE_API_KEY=your_rebrickable_api_key_here

# Comma-separated list of browser origins allowed to call /api/**
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT signing secret (HS256) - MUST be at least 32 bytes. Override in every environment.
JWT_SECRET=change-me-to-a-long-random-at-least-32-byte-secret
JWT_EXPIRATION_MINUTES=120